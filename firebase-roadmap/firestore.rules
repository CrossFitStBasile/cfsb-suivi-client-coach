rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function profile() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function activeUser() {
      return signedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && profile().data.active == true;
    }

    function isOwner() {
      return activeUser() && profile().data.role in ['owner', 'admin'];
    }

    function isMember() {
      return activeUser()
        && profile().data.role == 'member'
        && profile().data.teamMemberId is string;
    }

    function ownsTeamMember(teamMemberId) {
      return isMember() && profile().data.teamMemberId == teamMemberId;
    }

    function validPortalInvitation(teamMemberId) {
      return signedIn()
        && teamMemberId is string
        && exists(/databases/$(database)/documents/portalInvitations/$(teamMemberId))
        && get(/databases/$(database)/documents/portalInvitations/$(teamMemberId)).data.active == true
        && get(/databases/$(database)/documents/portalInvitations/$(teamMemberId)).data.email == request.auth.token.email;
    }

    function canSubmitRoadmap(teamMemberId) {
      return isOwner()
        || ownsTeamMember(teamMemberId)
        || validPortalInvitation(teamMemberId);
    }

    function ownsDocument(uid) {
      return signedIn() && uid == request.auth.uid;
    }

    match /users/{userId} {
      allow read: if (signedIn() && request.auth.uid == userId) || isOwner();
      allow create: if isOwner() || (
        signedIn()
        && request.auth.uid == userId
        && request.resource.data.active == true
        && request.resource.data.role == 'member'
        && request.resource.data.email == request.auth.token.email
        && validPortalInvitation(request.resource.data.teamMemberId)
      );
      allow update, delete: if isOwner();
    }

    match /roadmapForms/{formVersion} {
      allow read: if true;
      allow create, update, delete: if isOwner();
    }

    match /roadmapCycles/{cycleId} {
      allow read: if resource.data.public == true || isOwner();
      allow create, update, delete: if isOwner();
    }

    match /orgDepartments/{departmentId} {
      allow read: if true;
      allow create, update, delete: if isOwner();
    }

    match /teamMembers/{memberId} {
      allow read: if resource.data.active == true || isOwner() || ownsTeamMember(memberId);
      allow create, update, delete: if isOwner();
    }

    match /teamMemberPrivate/{memberId} {
      allow read, create, update, delete: if isOwner();
    }

    match /memberPortalProfiles/{memberId} {
      allow read: if isOwner() || ownsTeamMember(memberId);
      allow create, update, delete: if isOwner();
    }

    match /portalInvitations/{memberId} {
      allow read: if isOwner() || (
        signedIn()
        && resource.data.active == true
        && resource.data.email == request.auth.token.email
      );
      allow create, update, delete: if isOwner();
    }

    match /roadmapDrafts/{draftId} {
      allow create: if signedIn()
        && request.resource.data.authorUid == request.auth.uid
        && canSubmitRoadmap(request.resource.data.teamMemberId)
        && request.resource.data.status == 'draft';
      allow read: if isOwner() || ownsDocument(resource.data.authorUid);
      allow update: if isOwner() || (
        ownsDocument(resource.data.authorUid)
        && resource.data.status == 'draft'
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.clientSubmissionId == resource.data.clientSubmissionId
        && canSubmitRoadmap(request.resource.data.teamMemberId)
        && request.resource.data.status in ['draft', 'submitted']
        && (
          request.resource.data.status == 'draft'
          || existsAfter(/databases/$(database)/documents/roadmapSubmissions/$(resource.data.clientSubmissionId))
        )
      );
      allow delete: if isOwner() || (
        ownsDocument(resource.data.authorUid)
        && resource.data.status == 'draft'
      );
    }

    match /roadmapSubmissions/{submissionId} {
      allow create: if signedIn()
        && request.resource.data.authorUid == request.auth.uid
        && canSubmitRoadmap(request.resource.data.teamMemberId)
        && request.resource.data.clientSubmissionId == submissionId
        && request.resource.data.status == 'to_read'
        && request.resource.data.source == 'firebase'
        && request.resource.data.cycleId is string
        && request.resource.data.formVersion is string
        && request.resource.data.selectedRoleId is string
        && request.resource.data.answers is map;
      allow read: if isOwner()
        || ownsDocument(resource.data.authorUid)
        || ownsTeamMember(resource.data.teamMemberId);
      allow update, delete: if isOwner();

      match /events/{eventId} {
        allow read: if isOwner();
        allow create: if isOwner();
        allow update, delete: if false;
      }
    }

    match /ownerNotes/{submissionId} {
      allow read, create, update, delete: if isOwner();
    }

    match /careerMilestones/{milestoneId} {
      allow read: if isOwner() || ownsTeamMember(resource.data.teamMemberId);
      allow create, update, delete: if isOwner();
    }

    match /careerUpdates/{updateId} {
      allow read: if isOwner() || ownsTeamMember(resource.data.teamMemberId);
      allow create: if isOwner();
      allow update, delete: if false;
    }

    match /memberCareerPlans/{memberId} {
      allow read: if isOwner() || ownsTeamMember(memberId);
      allow create: if isOwner() || (
        ownsTeamMember(memberId)
        && request.resource.data.teamMemberId == memberId
        && request.resource.data.updatedByUid == request.auth.uid
      );
      allow update: if isOwner() || (
        ownsTeamMember(memberId)
        && resource.data.teamMemberId == memberId
        && request.resource.data.teamMemberId == memberId
        && request.resource.data.updatedByUid == request.auth.uid
      );
      allow delete: if isOwner();
    }

    match /memberCareerPlanEvents/{eventId} {
      allow read: if isOwner() || ownsTeamMember(resource.data.teamMemberId);
      allow create: if activeUser()
        && (isOwner() || ownsTeamMember(request.resource.data.teamMemberId))
        && request.resource.data.createdByUid == request.auth.uid;
      allow update, delete: if false;
    }

    match /memberSharedSummaries/{summaryId} {
      allow read: if isOwner() || ownsTeamMember(resource.data.teamMemberId);
      allow create, update, delete: if isOwner();
    }

    match /teamMeetings/{meetingId} {
      allow read: if isOwner();
      allow create: if isOwner()
        && request.resource.data.status == 'draft';
      allow update: if isOwner()
        && resource.data.status == 'draft'
        && request.resource.data.status in ['draft', 'finalized'];
      allow delete: if isOwner()
        && resource.data.status == 'draft';
    }

    match /managementTasks/{taskId} {
      allow read, create, update, delete: if isOwner();
    }

    match /pilotageMetrics/{metricId} {
      allow read, create, update, delete: if isOwner();
    }

    match /pilotageMetricEntries/{entryId} {
      allow read, create, update, delete: if isOwner();
    }

    match /pilotageRocks/{rockId} {
      allow read, create, update, delete: if isOwner();
    }

    match /pilotageIssues/{issueId} {
      allow read, create, update, delete: if isOwner();
    }

    match /pilotageMeetings/{meetingId} {
      allow read, create, update, delete: if isOwner();
    }

    match /revenueScenarios/{scenarioId} {
      allow read: if isOwner() || (
        ownsTeamMember(resource.data.teamMemberId)
        && resource.data.visibility in ['member', 'shared']
      );
      allow create: if isOwner() || (
        ownsTeamMember(request.resource.data.teamMemberId)
        && request.resource.data.authorUid == request.auth.uid
        && request.resource.data.visibility == 'member'
      );
      allow update: if isOwner() || (
        ownsTeamMember(resource.data.teamMemberId)
        && resource.data.authorUid == request.auth.uid
        && request.resource.data.teamMemberId == resource.data.teamMemberId
        && request.resource.data.authorUid == resource.data.authorUid
        && request.resource.data.visibility == 'member'
      );
      allow delete: if isOwner() || (
        ownsTeamMember(resource.data.teamMemberId)
        && resource.data.authorUid == request.auth.uid
        && resource.data.visibility == 'member'
      );
    }

    match /notificationJobs/{jobId} {
      allow read: if isOwner();
      allow create, update, delete: if false;
    }

    match /auditLogs/{logId} {
      allow read: if isOwner();
      allow create: if activeUser();
      allow update, delete: if false;
    }

    match /clientErrors/{errorId} {
      allow read, update, delete: if isOwner();
      allow create: if activeUser();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
