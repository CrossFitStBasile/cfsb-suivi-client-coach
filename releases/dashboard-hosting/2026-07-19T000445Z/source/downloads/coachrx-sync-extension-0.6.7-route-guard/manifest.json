{
  "manifest_version": 3,
  "name": "CFSB CoachRx Sync",
  "version": "0.6.7",
  "description": "Synchronise les donnees CoachRx avec identite client, route de synchronisation geree et coordonnees de rapprochement fiables.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://dashboard.coachrx.app/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*"
  ],
  "action": {
    "default_title": "CFSB CoachRx Sync",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
