rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function profile() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid));
    }

    function activeUser() {
      return signedIn()
        && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid))
        && profile().data.active == true;
    }

    function coachId() {
      return profile().data.coachId;
    }

    function isPilotCoachId(coachField) {
      return coachField == '15935'
        || coachField == '15928'
        || coachField == '17242'
        || coachField == '15902'
        || coachField == '15893'
        || coachField == '15937'
        || coachField == '15936';
    }

    function isActiveCoach() {
      return activeUser()
        && profile().data.role == 'coach'
        && profile().data.coachId is string
        && isPilotCoachId(profile().data.coachId);
    }

    function canAccessCoachVoicePath(pathCoachId) {
      return isActiveCoach() && pathCoachId == coachId();
    }

    match /taskVoiceNotes/{coachId}/{taskId}/{fileName} {
      allow read: if canAccessCoachVoicePath(coachId);
      allow create, update: if canAccessCoachVoicePath(coachId)
        && request.resource.size < 8 * 1024 * 1024
        && request.resource.contentType.matches('audio/.*');
      allow delete: if canAccessCoachVoicePath(coachId);
    }
  }
}
